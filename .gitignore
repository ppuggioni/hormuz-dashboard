# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated dashboard data artifacts
/public/data/processed*.json
/public/data/processed*.json.gz
/public/data/news_feed.json
/public/data/vessel_attacks_latest.json
/public/data/iran_updates.json
/public/data/iran_update_figures.json
/public/data/iran_update_figures/*
/public/data/usni_fleet_tracker.json
/public/data/usni_fleet_maps/*
/public/data/confirmed_crossing_exclusions.json

# news pipeline runtime state
/data/news-history.json
/data/news-inbox.json
/data/news-latest-run.json
/data/news-run-artifacts/*.json
/data/attacks-run-artifacts/*.json
/data/iran-update-history.json
/data/iran-update-latest-run.json
/data/iran-update-publish-state.json
/data/iran-update-figure-extractions/
/data/usni-fleet-history.json
/data/usni-fleet-latest-run.json
/data/usni-fleet-map-extractions.json
/data/usni-fleet-telegram-state.json

# incremental pipeline runtime state
/state/*.json
/state/*.jsonl
/state/*.lock
!/state/.gitignore
!/state/README.md

# windowed rolling-pipeline runtime state
/data/input-snapshots/
/data/windowed-pipeline*/
/public/data-windowed*/
