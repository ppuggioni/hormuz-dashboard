{
  "name": "hormuz-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:data && npm run build:news && next dev",
    "build:data": "node scripts/build-data.mjs",
    "windowed:baseline": "node scripts/run-windowed-baseline.mjs",
    "windowed:refresh": "node scripts/run-windowed-refresh.mjs",
    "windowed:rerun-all": "node scripts/run-windowed-rerun-all.mjs",
    "ingest:news": "node scripts/ingest-news.mjs",
    "build:news": "node scripts/build-news.mjs",
    "build": "npm run build:news && next build",
    "start": "next start",
    "lint": "eslint",
    "test:incremental": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
